# Python
.venv/
__pycache__/
*.pyc

# Secrets
.env

# 真實設定（只 commit *.example.*，真實檔含公司/人設隱私）
personas.yaml
users.yaml
company.md
# stage14-signals 公司自動調查產出（{slug}-company.md）——跟 company.md
# 同一種隱私考量，副檔名不會誤擋 company.example.md（那是 .example.md）
*-company.md

# 記憶與 checkpointer（含會議內容）
chroma_db/
*.sqlite
*.sqlite3

# 產出（逐字稿、事件流、報告皆含會議內容）
outputs/

# stage10 產生 demo 樣本用的隔離工作區（跟 outputs/ 同一種東西，只是
# 路徑不同，不受用者真實的 practice/outputs/ 影響）
practice/stage10/demo_workspace/

# 唯一允許 commit 的產出：demo 用虛構樣本（來自 personas.example.yaml 等
# 公開範例設定跑出來的，內容全虛構，安全公開）
!demo/sample-run/
